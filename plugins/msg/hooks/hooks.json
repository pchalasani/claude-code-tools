{
  "description": "Stop hook for msg inter-agent communication. Checks inbox on stop for Claude Code sessions.",
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'python3 ${CLAUDE_PLUGIN_ROOT}/hooks/stop_hook.py'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
